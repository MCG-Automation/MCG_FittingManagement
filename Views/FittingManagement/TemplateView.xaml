<UserControl x:Class="MCG_FittingManagement.Views.FittingManagement.TemplateView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#FFF2F2F2"
             FontSize="11">

    <UserControl.Resources>
        <ResourceDictionary Source="FittingStyles.xaml"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Margin="0,5,0,0">
        <StackPanel TextElement.FontWeight="Normal" Margin="4">

            <GroupBox Header="FITTING TABLE">
                <StackPanel>
                    <TextBlock Text="Open the Fitting Table window to browse, import, and manage all fittings of the current Project Folder." Style="{StaticResource HelperTextStyle}"/>
                    <Button x:Name="BtnOpenMasterLibrary" Content="Open Fitting Table" Style="{StaticResource PrimaryButtonStyle}" Click="BtnOpenMasterLibrary_Click"/>
                </StackPanel>
            </GroupBox>

        </StackPanel>
    </ScrollViewer>
</UserControl>
