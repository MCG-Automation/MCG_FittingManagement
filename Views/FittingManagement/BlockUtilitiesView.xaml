<UserControl x:Class="MCGCadPlugin.Views.FittingManagement.BlockUtilitiesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#FFF2F2F2"
             FontSize="11">

    <UserControl.Resources>
        <ResourceDictionary Source="FittingStyles.xaml"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Margin="0,5,0,0">
        <StackPanel TextElement.FontWeight="Normal" Margin="4">

            <GroupBox Header="BLOCK UTILITIES">
                <StackPanel>
                    <TextBlock Text="Modify existing blocks without breaking references. Sync, replace, add or extract nested entities on the fly." Style="{StaticResource HelperTextStyle}"/>

                    <Button x:Name="BtnRenameCloneBlock" Content="Rename Block" Click="BtnRenameCloneBlock_Click" FontWeight="SemiBold"/>
                    <Button x:Name="BtnRedefineBlocks" Content="Redefine Blocks" Click="BtnRedefineBlocks_Click"/>
                    <Button x:Name="BtnSmartReplace" Content="Replace Block" Click="BtnSmartReplace_Click"/>
                    <Button x:Name="BtnChangeBasePoint" Content="Change Insertion Point" Click="BtnChangeBasePoint_Click"/>
                    <Button x:Name="BtnAddToBlock" Content="Add Objects to Block" Click="BtnAddToBlock_Click"/>
                    <Button x:Name="BtnExtractFromBlock" Content="Extract Objects from Block" Click="BtnExtractFromBlock_Click" Margin="0"/>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="DRAWING COLLECTION">
                <StackPanel>
                    <TextBlock Text="Collect Model Space from multiple .dwg files into the current drawing. Blocks are renamed [FileName]_[BlockName] (A1 and CAS_HEAD preserved), unused definitions are purged, and drawings are laid out horizontally with a 1000-unit gap." Style="{StaticResource HelperTextStyle}"/>

                    <Button x:Name="BtnCollectDrawings" Content="Collect Drawings (.dwg)" Style="{StaticResource PrimaryButtonStyle}" Click="BtnCollectDrawings_Click"/>
                    <TextBlock x:Name="TxtCollectionStatus" Text="" Foreground="#FF005E9E" FontStyle="Italic" Margin="0,6,0,0" TextWrapping="Wrap"/>
                </StackPanel>
            </GroupBox>

        </StackPanel>
    </ScrollViewer>
</UserControl>
