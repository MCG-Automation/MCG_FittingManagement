<UserControl x:Class="MCGCadPlugin.Views.FittingManagement.ProjectConfigView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#FFF2F2F2"
             FontSize="11">

    <UserControl.Resources>
        <ResourceDictionary Source="FittingStyles.xaml"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Margin="0,5,0,0">
        <StackPanel TextElement.FontWeight="Normal" Margin="4">

            <GroupBox Header="FITTING LIBRARY">
                <StackPanel>
                    <TextBlock Text="Open the Fitting Library to browse project-configured fittings and insert into the current drawing." Style="{StaticResource HelperTextStyle}"/>
                    <Button x:Name="BtnOpenLibrary" Content="Open Fitting Library" Style="{StaticResource PrimaryButtonStyle}" Click="BtnOpenLibrary_Click"/>
                </StackPanel>
            </GroupBox>

        </StackPanel>
    </ScrollViewer>
</UserControl>
