<UserControl x:Class="MCG_FittingManagement.Views.FittingManagement.FittingPreviewPane"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FontFamily="Segoe UI" FontSize="11"
             Background="#FFFAFAFA">
    <UserControl.Resources>
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FF888888"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,8,2"/>
        </Style>
        <Style x:Key="ValueStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FF222222"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>
    </UserControl.Resources>

    <Grid x:Name="RootGrid" Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Image area: 280x280 square -->
        <Border Grid.Row="0" Background="White" BorderBrush="#FFDEDEDE" BorderThickness="1"
                Width="280" Height="280" Margin="10" HorizontalAlignment="Center">
            <Grid>
                <Image x:Name="PreviewImage" Stretch="Uniform" Margin="6"/>
                <TextBlock x:Name="NoPreviewText" Text="No Preview"
                           Foreground="#FFAAAAAA" FontSize="14"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Visibility="Collapsed"/>
            </Grid>
        </Border>

        <!-- Properties area -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Margin="14,0,14,10">
            <StackPanel>
                <TextBlock x:Name="TxtPartNumber" FontSize="14" FontWeight="Bold" Foreground="#FF005E9E" Margin="0,0,0,4"/>
                <TextBlock x:Name="TxtTitle" FontStyle="Italic" Foreground="#FF555555" TextWrapping="Wrap" Margin="0,0,0,10"/>

                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Description" Style="{StaticResource LabelStyle}"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" x:Name="TxtDescription" Style="{StaticResource ValueStyle}"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Mass" Style="{StaticResource LabelStyle}"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" x:Name="TxtMass" Style="{StaticResource ValueStyle}"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Material" Style="{StaticResource LabelStyle}"/>
                    <TextBlock Grid.Row="2" Grid.Column="1" x:Name="TxtMaterial" Style="{StaticResource ValueStyle}"/>

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Designer" Style="{StaticResource LabelStyle}"/>
                    <TextBlock Grid.Row="3" Grid.Column="1" x:Name="TxtDesigner" Style="{StaticResource ValueStyle}"/>

                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Revision" Style="{StaticResource LabelStyle}"/>
                    <TextBlock Grid.Row="4" Grid.Column="1" x:Name="TxtRevision" Style="{StaticResource ValueStyle}"/>

                    <TextBlock Grid.Row="5" Grid.Column="0" Text="UoM" Style="{StaticResource LabelStyle}"/>
                    <TextBlock Grid.Row="5" Grid.Column="1" x:Name="TxtUoM" Style="{StaticResource ValueStyle}"/>

                    <TextBlock Grid.Row="6" Grid.Column="0" Text="Block Name" Style="{StaticResource LabelStyle}"/>
                    <TextBlock Grid.Row="6" Grid.Column="1" x:Name="TxtBlockName" Foreground="#FF888888" FontSize="10" TextWrapping="Wrap"/>
                </Grid>
            </StackPanel>
        </ScrollViewer>

        <!-- Empty-state overlay (item null) -->
        <Border x:Name="EmptyState" Grid.RowSpan="2" Background="#FFFAFAFA" Visibility="Collapsed">
            <TextBlock x:Name="EmptyStateText" Text="Select an item to preview"
                       Foreground="#FFAAAAAA" FontStyle="Italic"
                       HorizontalAlignment="Center" VerticalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center"
                       Margin="20"/>
        </Border>

        <!-- Metadata card cho non-block items (CAD-Linear như dây, ống...) -->
        <Border x:Name="MetadataCard" Grid.RowSpan="2" Background="#FFFAFAFA" Visibility="Collapsed">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Margin="14,12,14,10">
                <StackPanel>
                    <!-- Type badge -->
                    <Border Background="#FFE8F4FF" BorderBrush="#FFAACCE8" BorderThickness="1"
                            CornerRadius="4" Padding="8,4" Margin="0,0,0,6" HorizontalAlignment="Left">
                        <TextBlock x:Name="CardEntityType" FontWeight="Bold" FontSize="12" Foreground="#FF005E9E"/>
                    </Border>

                    <!-- Source badge -->
                    <Border Background="#FFEEF7EE" BorderBrush="#FF90C890" BorderThickness="1"
                            CornerRadius="4" Padding="6,2" Margin="0,0,0,14" HorizontalAlignment="Left">
                        <TextBlock x:Name="CardSource" FontSize="10" FontWeight="SemiBold" Foreground="#FF2E7D32"/>
                    </Border>

                    <!-- Part ID + Title -->
                    <TextBlock x:Name="CardPartNumber" FontSize="13" FontWeight="Bold" Foreground="#FF005E9E" Margin="0,0,0,2"/>
                    <TextBlock x:Name="CardTitle" FontStyle="Italic" Foreground="#FF555555" TextWrapping="Wrap" Margin="0,0,0,12"/>

                    <Border Height="1" Background="#FFDDDDDD" Margin="0,0,0,12"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Layer" Style="{StaticResource LabelStyle}"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" x:Name="CardLayer" Style="{StaticResource ValueStyle}"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="UoM" Style="{StaticResource LabelStyle}"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" x:Name="CardUoM" Style="{StaticResource ValueStyle}"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Description" Style="{StaticResource LabelStyle}"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" x:Name="CardDescription" Style="{StaticResource ValueStyle}"/>

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Mass" Style="{StaticResource LabelStyle}"/>
                        <TextBlock Grid.Row="3" Grid.Column="1" x:Name="CardMass" Style="{StaticResource ValueStyle}"/>

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="BOM Type" Style="{StaticResource LabelStyle}"/>
                        <TextBlock Grid.Row="4" Grid.Column="1" x:Name="CardBomType" Style="{StaticResource ValueStyle}"/>

                        <TextBlock Grid.Row="5" Grid.Column="0" Text="Designer" Style="{StaticResource LabelStyle}"/>
                        <TextBlock Grid.Row="5" Grid.Column="1" x:Name="CardDesigner" Style="{StaticResource ValueStyle}"/>
                    </Grid>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
