<Window x:Class="MCG_FittingManagement.Views.FittingManagement.AutoAssignStartDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Auto-Assign Pos" Height="180" Width="320"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#FFF0F0F0" FontFamily="Segoe UI" FontSize="13">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Assign Position Numbers to DETAIL/HULL fittings (grouped by Part Number)."
                   FontWeight="SemiBold" Foreground="#FF333333" TextWrapping="Wrap"/>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="90"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Start from:" Grid.Column="0" VerticalAlignment="Center" Foreground="#FF444444"/>
            <TextBox x:Name="TxtStartNumber" Grid.Column="1" Height="28" Padding="6,0"
                     VerticalContentAlignment="Center" Text="1"
                     Background="White" BorderBrush="#FFCCCCCC"
                     KeyDown="TxtStartNumber_KeyDown"/>
        </Grid>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Width="80" Height="28" Margin="0,0,8,0"
                    Click="BtnCancel_Click" Background="#FFE0E0E0"/>
            <Button x:Name="BtnOk" Content="OK" Width="100" Height="28"
                    Background="#FF0055A5" Foreground="White" FontWeight="Bold"
                    Click="BtnOk_Click" IsDefault="True"/>
        </StackPanel>
    </Grid>
</Window>
