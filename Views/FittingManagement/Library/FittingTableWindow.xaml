<Window x:Class="MCG_FittingManagement.Views.FittingManagement.FittingTableWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shared="clr-namespace:MCG_FittingManagement.Views.FittingManagement"
        Title="MacGregor Fitting Table" Height="680" Width="1620"
        WindowStartupLocation="CenterScreen"
        Background="#FFF0F0F0" FontFamily="Segoe UI">

    <Window.Resources>
        <Style TargetType="Button" x:Key="PrimaryButtonStyle">
            <Setter Property="Background" Value="#FF0055A5"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FF004080"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SearchTextBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="26"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="5,0"/>
            <Style.Resources>
                <VisualBrush x:Key="HelpBrush" TileMode="None" Opacity="0.4" Stretch="None" AlignmentX="Left">
                    <VisualBrush.Visual>
                        <TextBlock FontStyle="Italic" Padding="5,0,0,0" Text="Search by Part ID, Name, Desc, Originator, View (e.g., 'sheave 22')..."/>
                    </VisualBrush.Visual>
                </VisualBrush>
            </Style.Resources>
            <Style.Triggers>
                <Trigger Property="Text" Value="{x:Null}">
                    <Setter Property="Background" Value="{StaticResource HelpBrush}"/>
                </Trigger>
                <Trigger Property="Text" Value="">
                    <Setter Property="Background" Value="{StaticResource HelpBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#FFE8E8E8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="6,8"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="BorderBrush" Value="#FFDEDEDE"/>
            <Setter Property="Foreground" Value="#FF333333"/>
            <EventSetter Event="PreviewMouseRightButtonDown" Handler="ColumnHeader_PreviewMouseRightButtonDown"/>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal">
                <TextBlock Text="FITTING TABLE" FontSize="16" FontWeight="Bold" Foreground="#FF0055A5" VerticalAlignment="Center"/>
                <Border Background="#FF0055A5" CornerRadius="3" Padding="6,2" Margin="10,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="LIBRARY" Foreground="White" FontSize="10" FontWeight="Bold"/>
                </Border>
            </StackPanel>

            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Active Project:" Margin="0,0,5,0" VerticalAlignment="Center" FontWeight="SemiBold"/>
                <TextBox x:Name="TxtActiveProject" Width="160" IsReadOnly="True" Background="#FFE8E8E8" Margin="0,0,5,0" VerticalContentAlignment="Center" ToolTip="Project Folder hiện tại — Load Folder để đổi."/>
                <Button x:Name="BtnLoadFolder" Content="Load Folder" Width="95" Height="26" Click="BtnLoadFolder_Click" ToolTip="Chọn Project Folder — tự tìm hoặc tạo mới FittingCatalog.json bên trong."/>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Global Search:" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="SemiBold"/>
            <TextBox Grid.Column="1" x:Name="TxtSearch" Style="{StaticResource SearchTextBoxStyle}" TextChanged="TxtSearch_TextChanged" ToolTip="Multi-keyword search is supported. Type keywords separated by space."/>
        </Grid>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="320" MinWidth="200"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="White" BorderBrush="#FFDEDEDE" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" BorderBrush="#FFDEDEDE" BorderThickness="0,0,0,1" Background="#FFE8E8E8">
                        <TextBlock Text="Categories (Group by Name)" FontWeight="SemiBold" Padding="8,6" Foreground="#FF333333"/>
                    </Border>

                    <TreeView Grid.Row="1" x:Name="TreeCategories" SelectedItemChanged="TreeCategories_SelectedItemChanged" BorderThickness="0" Padding="5" AllowDrop="True">
                        <TreeView.ItemTemplate>
                            <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                <Border x:Name="RowBorder" Padding="2,1" CornerRadius="2">
                                    <StackPanel Orientation="Horizontal" Margin="0,3">
                                        <TextBlock Text="📁 " Foreground="#FFDEB887"/>
                                        <TextBlock Text="{Binding CategoryName}" FontWeight="SemiBold" Foreground="#FF333333"/>
                                        <TextBlock Text="{Binding CountLabel}" Foreground="#FF888888" Margin="5,0,0,0"/>
                                    </StackPanel>
                                </Border>
                                <HierarchicalDataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding IsMultiSelected}" Value="True">
                                        <Setter TargetName="RowBorder" Property="Background" Value="#FFCCE5FF"/>
                                    </DataTrigger>
                                </HierarchicalDataTemplate.Triggers>
                            </HierarchicalDataTemplate>
                        </TreeView.ItemTemplate>
                        <TreeView.ItemContainerStyle>
                            <Style TargetType="TreeViewItem">
                                <Setter Property="IsExpanded" Value="True"/>
                                <EventSetter Event="PreviewMouseRightButtonDown" Handler="TreeViewItem_PreviewMouseRightButtonDown"/>
                                <EventSetter Event="PreviewMouseLeftButtonDown" Handler="TreeViewItem_PreviewMouseLeftButtonDown"/>
                                <EventSetter Event="PreviewMouseMove" Handler="TreeViewItem_PreviewMouseMove"/>
                                <EventSetter Event="Drop" Handler="TreeViewItem_Drop"/>
                                <Setter Property="AllowDrop" Value="True"/>
                            </Style>
                        </TreeView.ItemContainerStyle>
                    </TreeView>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Center" Background="#FFF0F0F0" Margin="2,0"/>

            <DataGrid Grid.Column="2" x:Name="GridCatalog"
                      AutoGenerateColumns="False" CanUserAddRows="False"
                      IsReadOnly="True" SelectionMode="Extended"
                      Background="White" BorderBrush="#FFDEDEDE" RowHeight="26">
                <DataGrid.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Edit Properties" Click="BtnEditProperties_Click"/>
                        <MenuItem Header="Edit Pos Num" Click="BtnEditPosNum_Click"
                                  ToolTip="Sửa Project Pos Num của fitting."/>
                        <MenuItem Header="Edit View Type" Click="BtnEditViewType_Click"
                                  ToolTip="Đánh dấu Plan View / quy tắc đếm Qty theo Plan View cho Hull BOM khi 1 fitting có nhiều mặt cắt trong cùng 1 khung A1."/>
                        <MenuItem Header="Sync" Click="BtnSyncToDrawing_Click"
                                  ToolTip="Update block AttributeDefinitions and all INSERT instances in the current drawing."/>
                        <MenuItem Header="Sub-BOM / Accessories" Click="BtnManageAccessory_Click"
                                  ToolTip="Manage accessories attached to this fitting."/>
                        <Separator/>
                        <MenuItem Header="Remove from Project" Click="BtnRemoveFromMaster_Click" Foreground="#FFD32F2F"/>
                    </ContextMenu>
                </DataGrid.ContextMenu>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Type" Binding="{Binding EntityType}" Width="Auto" FontWeight="SemiBold" Foreground="#FF005E9E"/>
                    <DataGridTextColumn Header="Source" Binding="{Binding Source}" Width="80">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontSize" Value="10"/>
                                <Setter Property="Foreground" Value="#FF888888"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="View / File Name" Binding="{Binding BlockName}" Width="Auto" Foreground="#FF555555"/>
                    <DataGridTextColumn Header="Part Complete ID" Binding="{Binding PartNumber}" Width="Auto" FontWeight="Bold"/>
                    <DataGridTextColumn Header="Name" Binding="{Binding Title}" Width="Auto">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock"><Setter Property="TextWrapping" Value="Wrap"/></Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock"><Setter Property="TextWrapping" Value="Wrap"/></Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="Project Pos." Binding="{Binding ProjectPosNum}" Width="90">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="Foreground" Value="#FFD32F2F"/>
                                <Setter Property="TextAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                        <DataGridTextColumn.CellStyle>
                            <Style TargetType="DataGridCell">
                                <Setter Property="Background" Value="#FFFFF9C4"/>
                            </Style>
                        </DataGridTextColumn.CellStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="UoM" Binding="{Binding UoM}" Width="50">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock"><Setter Property="TextAlignment" Value="Center"/></Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Weight" Binding="{Binding Mass, StringFormat={}{0} kg}" Width="Auto"/>
                    <DataGridTextColumn Header="Originator" Binding="{Binding Designer}" Width="Auto"/>
                    <DataGridTextColumn Header="Created" Binding="{Binding CreatedDate}" Width="Auto">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontSize" Value="10"/>
                                <Setter Property="Foreground" Value="#FF888888"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                </DataGrid.Columns>
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <EventSetter Event="MouseDoubleClick" Handler="GridCatalog_MouseDoubleClick"/>
                        <EventSetter Event="PreviewMouseRightButtonDown" Handler="GridRow_PreviewMouseRightButtonDown"/>
                    </Style>
                </DataGrid.RowStyle>
            </DataGrid>

            <GridSplitter Grid.Column="3" Width="5" HorizontalAlignment="Center" Background="#FFF0F0F0" Margin="2,0"/>

            <Border Grid.Column="4" Background="#FFFAFAFA" BorderBrush="#FFDEDEDE" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" BorderBrush="#FFDEDEDE" BorderThickness="0,0,0,1" Background="#FFE8E8E8">
                        <TextBlock Text="Preview" FontWeight="SemiBold" Padding="8,6" Foreground="#FF333333"/>
                    </Border>
                    <shared:FittingPreviewPane Grid.Row="1" x:Name="PreviewPane"/>
                </Grid>
            </Border>
        </Grid>

        <Grid Grid.Row="3" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <Button x:Name="BtnAddFromCad" Content="➕ Add from CAD" Width="130" Margin="0,0,10,0" Click="BtnAddFromCad_Click" Background="#FF28A745" Foreground="White" FontWeight="Bold" Height="28"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="BtnAutoAssignPos" Content="Auto-Assign Pos" Width="120" Margin="0,0,10,0" Click="BtnAutoAssignPos_Click"/>
                <Button x:Name="BtnUpdateLibrary" Content="Push Update" Width="100" Margin="0,0,10,0" Click="BtnUpdateLibrary_Click"/>
                <Button x:Name="BtnRefresh" Content="Refresh" Width="70" Margin="0,0,10,0" Click="BtnRefresh_Click"/>
                <Button x:Name="BtnInsertFittingTable" Content="Insert Fitting Table" Width="150" Margin="0,0,10,0" Click="BtnInsertFittingTable_Click"
                        ToolTip="Chèn bảng lưới TẤT CẢ fitting trong Project (hoặc Category đang chọn) — mỗi hàng 1 fitting, gồm Pos/Part Number/Title/Views/Description/Material/Mass/UoM."/>
                <Button x:Name="BtnInsert" Content="Insert to CAD" Width="120" Style="{StaticResource PrimaryButtonStyle}" Click="BtnInsert_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
