<UserControl x:Class="MCGCadPlugin.Views.FittingManagement.FittingHandleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#FFF2F2F2"
             FontSize="11">

    <UserControl.Resources>
        <ResourceDictionary Source="FittingStyles.xaml"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Margin="0,5,0,0">
        <StackPanel TextElement.FontWeight="Normal" Margin="4">

            <GroupBox Header="BOM EXPORT">
                <StackPanel>
                    <TextBlock Text="Scan drawings, count fittings, auto-assign balloons, and export BOM matrix to Excel." Style="{StaticResource HelperTextStyle}"/>
                    <Button x:Name="BtnOpenBomPreview" Content="Open BOM Export" Style="{StaticResource PrimaryButtonStyle}" Click="BtnOpenBomPreview_Click"/>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="BALLOONING">
                <StackPanel>
                    <TextBlock Text="Place balloons on fittings — click continuously or auto-balloon by boundary." Style="{StaticResource HelperTextStyle}"/>
                    <Button x:Name="BtnAddBalloon" Content="Place Balloon" Click="BtnAddBalloon_Click" ToolTip="Click continuously to place balloons on fittings"/>
                    <Button x:Name="BtnMassBalloon" Content="Mass Auto-Balloon" Click="BtnMassBalloon_Click" ToolTip="Select a boundary to automatically balloon all fittings"/>
                </StackPanel>
            </GroupBox>

        </StackPanel>
    </ScrollViewer>
</UserControl>
